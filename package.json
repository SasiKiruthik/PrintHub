{
  "name": "secure-printhub",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Privacy-preserving printing — shop never sees document content",
  "author": "SecurePrintHub Team",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "dist": "vite build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^3.3.6",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.securePrintHub.app",
    "productName": "SecurePrintHub",
    "copyright": "SecurePrintHub 2025",
    "forceCodeSigning": false,
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ],
      "signingHashAlgorithms": null,
      "sign": null,
      "signDlls": false
    },
    "portable": {
      "artifactName": "SecurePrintHub-Portable.exe"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "npmRebuild": false
  }
}