# Environment Configuration

# Development
VITE_API_BASE_URL=http://localhost:4000
VITE_ENVIRONMENT=development
VITE_LOG_LEVEL=debug

# Production (Vercel)
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_ENVIRONMENT=production
# VITE_LOG_LEVEL=error

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CRASH_REPORTING=false

# App Configuration
VITE_APP_NAME=SecurePrintHub
VITE_APP_VERSION=1.0.0
VITE_PASSCODE_TIMEOUT_MS=150000
VITE_MAX_FILE_SIZE_MB=100

# Security
VITE_CRYPTO_ITERATIONS=100000
VITE_ALLOWED_FILE_TYPES=pdf,txt,jpg,jpeg,png,doc,docx,xls,xlsx

# WebRTC Configuration
VITE_ICE_GATHERING_TIMEOUT_MS=10000
VITE_DATA_CHANNEL_TIMEOUT_MS=15000

# Network
VITE_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
